FROM n8nio/n8n

ENV N8N_PORT=10000
ENV N8N_HOST=0.0.0.0

EXPOSE 10000services:
  - type: web
    name: n8n
    env: docker
    plan: free

    envVars:
      - key: N8N_BASIC_AUTH_ACTIVE
        value: true
      - key: N8N_BASIC_AUTH_USER
        value: admin
      - key: N8N_BASIC_AUTH_PASSWORD
        value: admin123

      - key: N8N_PORT
        value: 10000
      - key: N8N_HOST
        value: 0.0.0.0
